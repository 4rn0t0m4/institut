APP_NAME="Institut Corps à Coeur"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=institut_laravel
DB_USERNAME=root
DB_PASSWORD=

# Legacy WordPress DB (for data migration only)
#DB_WP_HOST=127.0.0.1
#DB_WP_PORT=3306
#DB_WP_DATABASE=institut_db
#DB_WP_USERNAME=root
#DB_WP_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

# Trusted proxies (set to * behind load balancer, or comma-separated IPs)
#TRUSTED_PROXIES=*

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Brevo in production)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS=admin@example.com
#BREVO_API_KEY=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Boxtal shipping
#BOXTAL_ACCESS_KEY=
#BOXTAL_SECRET_KEY=

# Google Analytics
#ANALYTICS_PROPERTY_ID=

# Claude AI (product enrichment)
#ANTHROPIC_API_KEY=

VITE_APP_NAME="${APP_NAME}"
